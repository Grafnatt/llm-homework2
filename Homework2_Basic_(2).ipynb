        "    test_size=0.2,\n",
        "    random_state=42,\n",
        "    stratify=df['label']\n",
        ")\n",
        "\n",
        "# 2. Разделение на train/val/test\n",
        "val_df, test_df = train_test_split(\n",
        "    temp_df,\n",
