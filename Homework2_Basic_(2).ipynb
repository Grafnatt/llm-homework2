        "from huggingface_hub import login, HfApi\n",
        "from datasets import Dataset, DatasetDict\n",
        "\n",
        "# Авторизация (вставьте ваш токен)\n",
        "login(token=\"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\")\n",
        "\n",
        "# === ВАШ КОД ЗДЕСЬ ===\n",
        "\n",
        "# 1. Создание DatasetDict из ваших DataFrame\n",
        "train_dataset = Dataset.from_pandas(train_df[['text', 'label']], preserve_index=False)\n",
        "val_dataset = Dataset.from_pandas(val_df[['text', 'label']], preserve_index=False)\n",
        "test_dataset = Dataset.from_pandas(test_df[['text', 'label']], preserve_index=False)\n",
        "\n",
        "# Объединяем их в одну структуру со стандартными именами подвыборок\n",
        "dataset_dict = DatasetDict({\n",
        "    'train': train_dataset,\n",
        "    'validation': val_dataset,\n",
        "    'test': test_dataset\n",
        "})\n",
        "\n",
        "# 2. Загрузка на Hub\n",
        "hf_username = \"grafnatt\"\n",
        "repo_name = \"ru-toxic-support-detector\"\n",
        "repo_id = f\"{hf_username}/{repo_name}\"\n",
        "\n",
        "print(f\"Загрузка датасета в репозиторий {repo_id}...\")\n",
        "dataset_dict.push_to_hub(repo_id)\n",
        "print(\"Датасет опубликован\")\n",
        "\n",
        "# === КОНЕЦ ВАШЕГО КОДА ===\n"
      ]
    },
