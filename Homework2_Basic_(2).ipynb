        "for label in [0, 1]:\n",
        "    sub_df = df[df['label'] == label]\n",
        "    label_name = \"Нетоксичный (0)\" if label == 0 else \"Токсичный (1)\"\n",
        "    print(f\"[{label_name}] Средняя длина: {sub_df['word_count'].mean():.1f} слов | \"\n",
        "          f\"Медианная длина: {sub_df['word_count'].median():.0f} слов | \"\n",
        "          f\"Максимальная длина: {sub_df['word_count'].max()} слов\")\n",
        "print(\"\\nСтатистика по количеству символов\")\n",
