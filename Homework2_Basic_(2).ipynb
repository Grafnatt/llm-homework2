        "import time\n",
        "import torch\n",
        "# === ВАШ КОД ЗДЕСЬ ===\n",
        "\n",
        "# 1. Функция predict_toxicity(text, device)\n",
        "# Должна возвращать: предсказанный класс (0 или 1), вероятность токсичности\n",
        "# ...\n",
        "def predict_toxicity(text, model, tokenizer, device):\n",
        "    model.eval()\n",
        "    model = model.to(device)\n",
        "\n",
        "    # Токенизация текста\n",
        "    inputs = tokenizer(\n",
        "        text,\n",
        "        max_length=128,\n",
        "        padding='max_length',\n",
        "        truncation=True,\n",
        "        return_tensors='pt'\n",
        "    )\n",
        "\n",
        "    # Перенос тензоров на нужный девайс\n",
        "    input_ids = inputs['input_ids'].to(device)\n",
        "    attention_mask = inputs['attention_mask'].to(device)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = model(input_ids=input_ids, attention_mask=attention_mask)\n",
        "        logits = outputs.logits\n",
        "        probs = torch.softmax(logits, dim=-1)\n",
        "\n",
        "        toxicity_prob = probs[0][1].item() # Вероятность класса \"токсично\"\n",
        "        pred_class = torch.argmax(logits, dim=1).item()\n",
        "\n",
        "    return pred_class, toxicity_prob\n",
        "# 2. Тестовые примеры\n",
        "test_texts = [\n",
        "    \"Здравствуйте, чем могу помочь?\",\n",
        "    \"Вы что, совсем тупой? Я же уже объяснял!\",\n",
        "    \"Пожалуйста, попробуйте перезагрузить устройство\",\n",
        "    \"Да пошел ты, надоел уже со своими вопросами\",\n",
        "    \"Ваш запрос принят, ожидайте ответа в течение 24 часов\",\n",
        "    \"Качество вашего сервиса просто 'потрясающее', так держать (нет).\",\n",
        "    \"Idiot, fix your terrible app right now!\",\n",
        "]\n",
        "\n",
        "# 3. Замер времени на GPU\n",
        "print(\"GPU\")\n",
        "for text in test_texts:\n",
        "    pred, prob = predict_toxicity(text, model, tokenizer, device='cuda')\n",
        "    status = \"токсично\" if pred == 1 else \"норма\"\n",
        "    print(f\"Текст: '{text}'\")\n",
        "    print(f\"Вердикт: {status} (Уверенность: {prob:.4f})\\n\")\n",
        "\n",
        "print(\"Замер скорости на GPU (CUDA)\")\n",
        "\n",
        "for _ in range(5):\n",
        "    _ = predict_toxicity(test_texts[0], model, tokenizer, device='cuda')\n",
        "\n",
        "torch.cuda.synchronize()\n",
        "start_gpu = time.time()\n",
        "for text in test_texts:\n",
        "    _ = predict_toxicity(text, model, tokenizer, device='cuda')\n",
        "torch.cuda.synchronize()\n",
        "end_gpu = time.time()\n",
        "gpu_time = end_gpu - start_gpu\n",
        "\n",
        "# 4. Замер времени на CPU\n",
        "print(\"Замер скорости на CPU\")\n",
        "start_cpu = time.time()\n",
        "for text in test_texts:\n",
        "    _ = predict_toxicity(text, model, tokenizer, device='cpu')\n",
        "end_cpu = time.time()\n",
        "cpu_time = end_cpu - start_cpu\n",
        "# 5. Сравнение результатов\n",
        "print(\"\\nСравнение производительности\")\n",
        "print(f\"Общее время обработки {len(test_texts)} текстов на GPU: {gpu_time:.4f} сек\")\n",
        "print(f\"Среднее время на 1 текст на GPU        : {gpu_time/len(test_texts):.4f} сек\")\n",
        "print(f\"Общее время обработки {len(test_texts)} текстов на CPU: {cpu_time:.4f} сек\")\n",
        "print(f\"Среднее время на 1 текст на CPU        : {cpu_time/len(test_texts):.4f} сек\")\n",
        "print(f\"GPU быстрее чем CPU в {cpu_time / gpu_time:.1f} раз")\n",
        "\n",
        "# === КОНЕЦ ВАШЕГО КОДА ===\n"
      ]
    },
